# ============================================================
# SPIDEYVERSE — Environment Variables
# Copy this file to .env.local and fill in all values.
# ALL keys below are REQUIRED unless marked [Optional].
# ============================================================

# --- Supabase (Required) ---
# Your project URL from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon (public) key — safe to expose client-side
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service Role key — SERVER ONLY. Never expose to the browser.
# Found in: Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI / LLM (Required) ---
# OpenAI API key for all agent reasoning (Research, Qualification, Outreach, Reporting)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# --- Lead Discovery (Required) ---
# Serper.dev — Google Search API for lead discovery
# Get from: https://serper.dev/api-key
SERPER_API_KEY=your-serper-api-key

# Apollo.io — B2B people/company intelligence
# Get from: https://app.apollo.io/#/settings/integrations/api
APOLLO_API_KEY=your-apollo-api-key

# --- Web Scraping (Optional — enables anti-bot bypass) ---
# Firecrawl — advanced scraping for company websites
# Without this key the extractor falls back to basic fetch.
# Get from: https://www.firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=your-firecrawl-api-key

# --- Email Delivery (Required for outreach sending) ---
# Resend — transactional email delivery
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# The verified sender email address for outreach messages.
# Must be a domain you have verified in your Resend account.
RESEND_FROM_EMAIL=outreach@yourdomain.com
